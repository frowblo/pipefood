# PipeFood — environment variables
# Copy to .env and fill in values. Never commit .env to git.

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
DB_PASSWORD=change_me_strong_password

# ---------------------------------------------------------------
# App security
# Generate with: openssl rand -hex 32
# ---------------------------------------------------------------
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# ---------------------------------------------------------------
# Anthropic — used for AI recipe import
# Get from: https://console.anthropic.com
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------
# Docker Hub — your Docker Hub username
# Images are expected as: yourusername/pipefood-backend:latest
#                          yourusername/pipefood-frontend:latest
# ---------------------------------------------------------------
DOCKER_HUB_USER=yourdockerhubusername
